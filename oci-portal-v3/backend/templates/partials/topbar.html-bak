<!-- templates/partials/topbar.html -->
<div class="portal">
  <div class="top-bar">
    <div class="app-title">
      <i class="ti ti-server-2"></i>
      NDEVR OCI Portal
    </div>
    <div class="who">
      <div class="avatar" id="user-avatar">AD</div>
      <span id="user-name"></span>
      <span id="user-email" style="color:var(--text-3)"></span>
      <span id="role-badge" class="r-admin"><i class="ti ti-crown" style="font-size:10px"></i>Admin</span>
      <button class="logout-btn" onclick="doLogout()">
        <i class="ti ti-logout"></i> Logout
      </button>
    </div>
  </div>
</div>
